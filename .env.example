# ============================================
# Tez Yordam EMS — Muhit O'zgaruvchilari
# ============================================

# --- Ilovaning umumiy sozlamalari ---
APP_NAME=Tez Yordam EMS
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Ma'lumotlar bazasi (PostgreSQL + PostGIS) ---
DATABASE_URL=postgresql+asyncpg://tez_yordam_user:tez_yordam_pass@localhost:5432/tez_yordam_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT sozlamalari ---
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OneID OAuth2/OIDC ---
ONEID_CLIENT_ID=your-oneid-client-id
ONEID_CLIENT_SECRET=your-oneid-client-secret
ONEID_AUTHORIZATION_URL=https://sso.egov.uz/sso/oauth/Authorization.do
ONEID_TOKEN_URL=https://sso.egov.uz/sso/oauth/Authorization.do
ONEID_USERINFO_URL=https://sso.egov.uz/sso/oauth/Authorization.do
ONEID_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# --- OpenAI Whisper API ---
OPENAI_API_KEY=your-openai-api-key
WHISPER_MODEL=whisper-1

# --- LLM Risk Scorer ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=your-llm-api-key

# --- SMS Provider (Eskiz.uz) ---
ESKIZ_EMAIL=your-eskiz-email
ESKIZ_PASSWORD=your-eskiz-password
ESKIZ_BASE_URL=https://notify.eskiz.uz/api

# --- Firebase Cloud Messaging ---
FCM_SERVER_KEY=your-fcm-server-key

# --- Shifrlash ---
ENCRYPTION_KEY=your-32-byte-encryption-key-here
